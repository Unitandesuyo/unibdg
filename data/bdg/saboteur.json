                                        "4枚",
                                        "4枚",
                                        "5枚",
                                        "5枚",
                                        "6枚",
                                        "7枚",
                                        "7枚"
                                    ],
                                    [
                                        "お邪魔者",
                                        "1枚",
                                        "1枚",
                                        "2枚",
                                        "2枚",
                                        "3枚",
                                        "3枚",
                                        "3枚",
                                        "4枚"
                                    ]
                                ]
                            },
                            {
                                "type": "text",
                                "content": [
                                    "山札からプレイ人数に応じて裏向きで配る。",
                                    "配った残りのカードは、裏向きの山札にしてゴールカードの脇に置く。",
                                    "金カードは山札にして邪魔にならない場所に置いておく。"
                                ]
                            },
                            {
                                "type": "table",
                                "headerFontSize": "0.8rem",
