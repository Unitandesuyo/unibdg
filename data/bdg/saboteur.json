                                "cellFontSize": "0.9rem",
                                "headers": [
                                    "人数",
                                    "3～5人",
                                    "6、7人",
                                    "8～10人"
                                ],
                                "rows": [
                                    [
                                        "手札枚数",
                                        "6枚",
                                        "5枚",
                                        "4枚"
                                    ]
                                ]
                            },
                            {
                                "type": "image",
                                "src": "images/sample.png",
                                "caption": "盤面イメージ"
                            }
