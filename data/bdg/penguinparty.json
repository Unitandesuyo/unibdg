    {
        "id": "penguinparty",
        "name": "ペンギンパーティ",
        "players": [
            2,
            6
        ],
        "time": 15,
        "tags": [
            "駆け引き",
            "初心者向け"
        ],
        "summary": {
            "image": "images/sample.png",
            "overview": "協力！？妨害！？\n同じ色のペンギンを繋げよう",
            "memo": "七ならべ的な"
        },
        "sections": [
            {
                "type": "accordion",
                "title": "勝利条件",
                "content": [
                    "人数分ラウンド終了後、",
                    "シャチチップが一番少ない人が勝利"
                ]
            },
            {
                "type": "accordion",
                "accordionType": "steps",
                "title": "ゲームの流れ",
                "content": [
                    {
                        "step": "準備",
                        "text": [
                            "カードを裏向きで全員に同じ枚数配る。",
                            "(5人で遊ぶ場合は1枚余る。これはテーブルの真ん中に置く)"
                        ]
                    },
                    {
                        "step": "①",
                        "text": [
                            "時計回りに手番を行う。",
                            "手札からカードを1枚出し、ペンギンのピラミッドを作っていく。",
                            "",
                            "(1)一番下にカードを置くとき、その段の端に置ける。",
                            "既に8枚並んでいるときは、それ以上置けない。",
                            "(2)2段目から上は、すぐ下の段で隣り合っている2枚の中間にのみカードを置ける。",
                            "この時、置くカードは下の2枚のどちらかと同じ色でないといけない。"
                        ]
                    },
                    {
                        "step": "②",
                        "text": [
                            "手番が来たときに出せるカードが無い人は、その時点で脱落。",
                            "手札の残り枚数分のポイントのシャチチップを受け取る。",
                            "残ったカードは公開せずに、自分の前に伏せておく。",
                            "脱落せず、手札のラスト1枚を出せた人は、ボーナスとしてシャチチップを2ポイントまでストックに返す。"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "全員が脱落するか、カードを出し切ったら1ゲーム終了。",
                            "最後の人も、手札が出せなかったらその分のシャチチップを受け取る。",
                            "シャチチップはそのままで、同じようにゲームを始める。",
                            "最初のプレイヤーはゲームごとに交代し、全員が1回ずつやる。",
                            "人数分のゲームが終了したとき、最もシャチチップが少ない人の勝ち。"
                        ]
                    }
                ]
            },
            {
                "type": "accordion",
                "title": "2人用",
                "content": [
                    "2人で遊ぶときは、それぞれ14枚カードを配り、残りの8枚は伏せておく。",
                    "7段ピラミッドでゲームを行う。"
                ]
            },
            {
                "type": "modal",
                "title": "Q&A",
                "modalType": "faq",
                "content": [
                    {
                        "question": "1段埋めないと上の段にいけない？",
                        "answer": [
                            "いいえ、下の2枚が置かれていたら、1段埋まっていなくても置いてよい。"
                        ]
                    },
                    {
                        "question": "シャチチップが同数の時は？",
                        "answer": [
                            "引き分け。(延長戦をしてもよし)"
                        ]
                    },
                    {
                        "question": "内容物について",
                        "answer": [
                            "ペンギンカード：36枚",
                            "(緑：8枚、黄/赤/紫/青：7枚)",
                            "シャチチップ：36枚",
                            "(1ポイント(黄)：24枚、5ポイント(赤)：12枚"
                        ]
                    }
                ]
            }
        ]
    }