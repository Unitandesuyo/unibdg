                    "調整中"
                ]
            },
            {
                "type": "modal",
                "title": "Q&A",
                "modalType": "faq",
                "content": [
                    {
                        "question": "コヨーテした数と場の数が同じだったときは？",
                        "answer": [
                            "コヨーテを宣言した人の負け"
                        ]
                    },
                    {
                        "question": "MAX→0が出たとき、最大値が複数同時に出ていたら？",
                        "answer": [
                            "すべてを0にして計算します"
                        ]
                    }
                ]
            }
