    {
        "id": "6nimmt",
        "name": "6 Nimmt!",
        "subtitle": "ニムト",
        "players": [
            2,
            10
        ],
        "time": 30,
        "tags": [
            "ワイワイ",
            "駆け引き"
        ],
        "summary": {
            "image": "images/construction.png",
            "overview": "牛が\"少ない\"人が勝ち！\n戦術問われるゲーム",
            "memo": "なんで牛なんだろう"
        },
        "sections": [
            {
                "type": "accordion",
                "title": "勝利条件",
                "content": [
                    "誰かが累計66点以上のマイナス点（牛）を取ったラウンド終了時、",
                    "マイナス点が最も少ないプレイヤーの勝利！"
                ]
            },
            {
                "type": "accordion",
                "accordionType": "steps",
                "title": "ゲームの流れ",
                "content": [
                    {
                        "step": "①",
                        "text": [
                            "1人10枚ずつカードを配る。"
                        ]
                    },
                    {
                        "step": "②",
                        "text": [
                            "残ったカードを4枚、表にして七並べのように並べる。"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "それぞれ手札から1枚選び、同時に表にする。"
                        ]
                    },
                    {
                        "step": "④",
                        "text": [
                            "数字の小さい人から順に処理していく。"
                        ]
                    },
                    {
                        "step": "⑤",
                        "text": [
                            "カードは「自分より小さい数字のうち、一番近い数字」の列の最後につなげる。",
                            "※強制"
                        ]
                    },
                    {
                        "step": "",
                        "text": [
                            "・列が6枚目になったとき、その前の5枚を引き取り、自分のカードを列の先頭に置く。",
                            "・どの列よりも小さい数字を出した場合は、好きな列を選んでカードを全て引き取り。その後、自分のカードをその列の先頭に置く。"
                        ]
                    },
                    {
                        "step": "⑥",
                        "text": [
                            "手札10枚をすべて使い切ったら1ラウンド終了。",
                            "以上を繰り返し、誰かが66点以上になったらそのラウンドでゲーム終了。",
                            "失点（牛）が一番少ない人の勝利。"
                        ]
                    }
                ]
            },
            {
                "type": "modal",
                "title": "Q&A",
                "modalType": "faq",
                "content": [
                    {
                        "question": "カードは全部で何枚？",
                        "answer": [
                            "1～104が各1枚。"
                        ]
                    },
                    {
                        "question": "牛は1枚につき何点？",
                        "answer": [
                            "1～7点。デカビタみたいな色の牛もいるよ。"
                        ]
                    },
                    {
                        "question": "なんで牛なの？",
                        "answer": [
                            "ドイツでは牛は「馬鹿」や「のろま」の象徴とされているらしい。かわいそう牛くん。"
                        ]
                    }
                ]
            }
        ]
    }