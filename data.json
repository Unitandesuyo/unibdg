[
    {
        "id": "coyote",
        "name": "コヨーテ",
        "players": [
            2,
            10
        ],
        "time": 15,
        "summary": {
            "image": "images/sample.png",
            "overview": "自分の数字が見えない状態で\n合計を読みあうブラフゲーム"
        },
        "sections": [
            {
                "type": "accordion",
                "accordionType": "steps",
                "title": "ゲームの流れ",
                "content": [
                    {
                        "step": "①",
                        "text": [
                            "１枚ずつカードを配り、自分のカードは見ずに、額に掲げる"
                        ]
                    },
                    {
                        "step": "②",
                        "text": [
                            "順番に１以上の整数を宣言し、数字を大きくしていく"
                        ]
                    },
                    {
                        "step": "",
                        "text": [
                            "※スタートは１でなくてもOK",
                            "※前の人より小さい数や小数は宣言できない",
                            "※前の人より大きければいくつでもOK <small>(例)1→2→20→22…</small>"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "前の人が宣言した数が、場(全員の掲げているカード)の合計数より大きいと思ったら「コヨーテ」と宣言"
                        ]
                    },
                    {
                        "step": "④",
                        "text": [
                            "場の合計数を計算し、宣言した数より大きければ前の人がアウト、以下であれば「コヨーテ」を宣言した人がアウト"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "ライフを-1し、ライフが0になれば離脱"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "使ったカードは公開して置いておく"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "①～⑥を最後の人になるまで続ける"
                        ]
                    }
                ]
            },
            {
                "type": "accordion",
                "title": "特殊カード・処理順",
                "content": [
                    "<heading>x2</heading>",
                    "場の数を合計したあと、その数を2倍する",
                    "<heading>MAX→0</heading>",
                    "場の最大値を0として計算する",
                    "<heading>？</heading>",
                    "山札を1枚めくり、その数を計算に加える",
                    "<heading>夜カード(黒い0カード)</heading>",
                    "0として計算する",
                    "その後、これまでに公開されたカードも全て山札に戻す",
                    "",
                    "<heading>処理順</heading>",
                    "？公開 <small>▷</small> MAX→0 <small>▷</small> 全て足す <small>▷</small> x2"
                ]
            },
            {
                "type": "modal",
                "title": "Q&A",
                "modalType": "faq",
                "content": [
                    {
                        "question": "コヨーテした数と場の数が同じだったときは？",
                        "answer": [
                            "A：コヨーテを宣言した人の負け"
                        ]
                    },
                    {
                        "question": "MAX→0が出たとき、最大値が複数同時に出ていたら？",
                        "answer": [
                            "A：すべてを0にして計算します"
                        ]
                    }
                ]
            }
        ]
    },
    {
        "id": "fogsite",
        "name": "FOGSITE(ﾌｫｸﾞｻｲﾄ)",
        "players": [
            2,
            4
        ],
        "time": 40,
        "summary": {
            "image": "images/sample.png",
            "overview": "遺跡を作る側、協力して脱出する側で戦う1対多の推理ゲーム！"
        },
        "sections": [
            {
                "type": "accordion",
                "title": "勝利条件",
                "content": [
                    "<heading>探検家</heading>",
                    "脱出に挑戦したとき、すべての探検家が同じマスにいる",
                    "",
                    "<heading>遺跡役</heading>",
                    "①探検家が脱出に挑戦したとき、誰か一人でも違うマスにいる",
                    "②時間切れ（フェイズ4終了後、遺跡役の出番になったとき）"
                ]
            },
            {
                "type": "accordion",
                "accordionType": "steps",
                "title": "ゲームの流れ",
                "content": [
                    {
                        "step": "①",
                        "text": [
                            "遺跡役（1人）を決める"
                        ]
                    },
                    {
                        "step": "②",
                        "text": [
                            "遺跡役は迷宮を作る（迷宮作成のルール 参照）、探検家は準備（リンク参照）、キャラクターカードを1枚選択"
                        ]
                    },
                    {
                        "step": "③",
                        "text": [
                            "ゲーム開始",
                            "遺跡役は、探検家1人を選び、｢衛兵がその探検家に最短でたどり着くまでの部屋の数｣を宣言"
                        ]
                    },
                    {
                        "step": "④",
                        "text": [
                            "探検家の手番",
                            "それぞれ順番に、｢探索｣｢移動｣｢能力使用｣から好きな行動を選択（順番・回数は自由）"
                        ]
                    },
                    {
                        "step": "⑤",
                        "text": [
                            "脱出への挑戦",
                            "探検家全員で相談して、脱出に挑戦するか決定する",
                            "挑戦する場合はゲーム終了、しない場合はゲーム続行"
                        ]
                    },
                    {
                        "step": "⑥",
                        "text": [
                            "行動予測",
                            "探検家は休憩カードか警戒カードのどちらかを選び、裏にして伏せる"
                        ]
                    },
                    {
                        "step": "⑦",
                        "text": [
                            "遺跡役の出番",
                            "｢移動｣｢攻撃｣｢パス｣から行動を選択"
                        ]
                    },
                    {
                        "step": "⑧",
                        "text": [
                            "①〜⑦を繰り返す",
                            "制限時間ボードの各フェイズマスから山がなくなるたび、｢フェイズの終了｣の処理を行う（④でも同様の処理を行う）",
                            "フェイズ4が終了すると、ゲーム終了"
                        ]
                    }
                ]
            },
            {
                "type": "modal",
                "title": "ゲーム準備（遺跡役）",
                "content": [
                    "あいうえお"
                ]
            },
            {
                "type": "modal",
                "title": "ゲーム準備（探検家）",
                "content": [
                    "調整中！"
                ]
            },
            {
                "type": "modal",
                "title": "詳しい流れ",
                "modalType": "detail",
                "content": [
                    {
                        "title": "タイトル１",
                        "image": "images/sample.png",
                        "text": [
                            "調整中"
                        ]
                    },
                    {
                        "title": "タイトル２",
                        "image": "images/sample2.png",
                        "text": [
                            "調整中"
                        ]
                    }
                ]
            },
            {
                "type": "modal",
                "title": "Q&A",
                "modalType": "faq",
                "content": [
                    {
                        "question": "調整中",
                        "answer": [
                            "A：調整中"
                        ]
                    }
                ]
            }
        ]
    },
